<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="0dp">

    <LinearLayout
        android:id="@+id/chatgpt_card"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/widget_card_bg"
        android:gravity="center"
        android:orientation="vertical">

        <!-- Dòng 1: Số dư và Tổng ví trên cùng 1 khối (chia 2 dòng) -->
        <LinearLayout
            android:id="@+id/widget_input_area"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingVertical="4dp"
            android:paddingLeft="6dp">

            <!-- Label Số dư -->
            <TextView
                android:id="@+id/widget_balance_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/noto_sans_regular"
                android:maxLines="1"
                android:text="Số dư"
                android:layout_gravity="left"
                android:textColor="#88FFFFFF"
                android:textSize="12sp" />

            <!-- Tổng ví -->
            <TextView
                android:id="@+id/widget_balance_amount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:fontFamily="@font/noto_sans_regular"
                android:maxLines="1"
                android:text="-- đ"
                android:layout_gravity="left"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Dòng 2: 2 nút bấm mỗi nút chia đôi 50% độ rộng màn -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/action_voice"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/widget_icon_bg"
                android:contentDescription="voice"
                android:elevation="0dp"
                android:padding="8dp"
                android:scaleType="fitCenter"
                android:src="@drawable/outline_keyboard_voice_24"
                android:tint="#FFFFFF" />

            <ImageButton
                android:id="@+id/action_image"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:background="@drawable/widget_icon_bg"
                android:contentDescription="image"
                android:elevation="0dp"
                android:padding="8dp"
                android:scaleType="fitCenter"
                android:src="@drawable/outline_image_24"
                android:tint="#FFFFFF" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
